APP_ENV=development

# docker-compose Postgres container settings
POSTGRES_OWNER_USER=dashboarduz_owner
POSTGRES_OWNER_PASSWORD=owner_dev_password
POSTGRES_DB=dashboarduz

# Owner/superuser DSN — used only by `python -m app.db.migrate`. Never used
# by the running app.
MIGRATIONS_DATABASE_URL=postgresql://dashboarduz_owner:owner_dev_password@localhost:5432/dashboarduz

# Least-privilege runtime DSN — the FastAPI app connects as this role.
# app_user is created by 0001_init.sql the first time migrations run.
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5432/dashboarduz
APP_DB_PASSWORD=app_user_dev_password

DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Ephemeral OTP / password-reset / registration-code storage (native Redis
# TTL, no manual expiry cleanup needed). DB index 1, not the shared default 0.
REDIS_URL=redis://localhost:6379/1

JWT_SECRET=change_me_generate_with_secrets_token_urlsafe
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PLATFORM_ACCESS_TOKEN_TTL_MINUTES=15
PLATFORM_REFRESH_TOKEN_TTL_DAYS=7

PASSWORD_RESET_TOKEN_TTL_MINUTES=30
OTP_CODE_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
TWO_FACTOR_PENDING_TTL_MINUTES=5

# Fernet key for encrypting integration secrets at rest (e.g. calls provider
# webhook secrets). Generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=change_me_generate_a_fernet_key

# S3-compatible object storage (call recordings). Leave endpoint empty to use
# real AWS S3; set it for local MinIO / self-hosted S3-compatible storage.
OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=dashboarduz-recordings
OBJECT_STORAGE_REGION=us-east-1

# Platform's own Payme/Click merchant account (collects tenant SaaS fees --
# not the per-tenant integration_credentials used by the calls module).
PAYME_MERCHANT_ID=change_me
PAYME_SECRET_KEY=change_me
CLICK_MERCHANT_ID=change_me
CLICK_SERVICE_ID=change_me
CLICK_SECRET_KEY=change_me

# Dunning ladder thresholds (days) for tenants.status: active -> past_due ->
# grace -> suspended.
BILLING_PAST_DUE_GRACE_DAYS=5
BILLING_GRACE_SUSPEND_DAYS=10

# Poll interval (seconds) for the notifications outbox background worker.
NOTIFICATION_WORKER_POLL_SECONDS=30

# Live Leaderboard SSE poll interval and dashboard-session token lifetime.
ANALYTICS_SSE_POLL_SECONDS=5
DASHBOARD_SESSION_TTL_HOURS=24

# Meta Ads campaign/insight sync poll interval (seconds).
META_ADS_SYNC_POLL_SECONDS=21600

# Real phone-OTP delivery (core/notify.py) via Telegram's official Gateway
# API (https://gateway.telegram.org/ account settings -> Copy Token). Leave
# empty to leave OTP codes log-only (dev default).
TELEGRAM_GATEWAY_API_TOKEN=

# Real email delivery (core/notify.py, password-reset + registration codes
# for email identifiers) via SMTP. Gmail: smtp.gmail.com:587 + a 16-char App
# Password (myaccount.google.com/apppasswords -- needs 2-Step Verification
# enabled first; the normal account password will NOT work). Leave
# SMTP_USERNAME empty to leave email codes log-only (dev default).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=
SMTP_SENDER_NAME=Dashboarduz

# Deployed frontend SPA's base URL -- used to build the clickable
# password-reset link emailed to users. Update once the frontend has a real
# public origin (see CLAUDE.md's Deployment section -- no domain yet).
FRONTEND_BASE_URL=http://localhost:5180

# Rate limiting (distributed via Redis when available)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_WEBHOOK_REQUESTS=120
RATE_LIMIT_WEBHOOK_WINDOW_SECONDS=60
RATE_LIMIT_GENERAL_REQUESTS=200
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
TRUST_X_FORWARDED_FOR=false

# Redis cache settings
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_ENABLED=true

# Structured logging
LOG_JSON_FORMAT=false
LOG_LEVEL=INFO

# Prometheus metrics
METRICS_ENABLED=true

# Grafana admin credentials (docker-compose only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
